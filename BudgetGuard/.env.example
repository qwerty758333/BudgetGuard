# Copy to .env.local for local dev. On Netlify, add the same keys in
# Site configuration → Environment variables (Vite bakes them at build time).

# Project URL from Supabase Dashboard → Settings → API (Project URL, NOT the REST URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin portal (comma-separated for multiple admins)
VITE_ADMIN_EMAIL=your-admin@example.com
VITE_ADMIN_USER_IDS=your-supabase-auth-user-uuid

# Optional judge/demo login (shown on Login page; auto-created on first use)
VITE_DEMO_EMAIL=demo@budgetguard.app
VITE_DEMO_PASSWORD=demo123456
